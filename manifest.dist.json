{
  "manifest_version": 3,
  "name": "Jira Plans Enhanced",
  "version": "0.4.0",
  "description": "Enhance Jira Plans with powerful features: headcount tracking, resource visibility, and more",
  "host_permissions": [
    "*://*.atlassian.net/*",
    "*://*.jira.com/*"
  ],
  "optional_host_permissions": [
    "*://*/*"
  ],
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.atlassian.net/jira/software/c/*/plans*",
        "*://*.atlassian.net/secure/*",
        "*://*.jira.com/jira/software/c/*/plans*",
        "*://*.jira.com/secure/*"
      ],
      "js": [
        "content/content-script.js"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Jira Plans Enhanced"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'self';"
  }
}
